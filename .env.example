# ============================================================
# CSL — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# .env.local is git-ignored — never commit real credentials.
# ============================================================

# ── Required for AI features ─────────────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase (optional — omit to use local-store mode) ───────
# When these are absent the CLI and services run entirely from
# a local JSON file (.csl-data.json) with no network calls.
# Get values from: Supabase Dashboard → Project Settings → API

# Public project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable / anon key (Supabase may label it either way)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alias accepted by the codebase — use one or the other:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, never expose to the browser
# Required for admin operations, migrations, and BDD tests
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres (optional — direct DB access for migrations) ────
# Dashboard → Project Settings → Database → Connection string
# Use port 5432 for migrations; port 6543 for serverless pooler
DATABASE_URL=
