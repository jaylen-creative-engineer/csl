# Supabase connection string — use the pooled (PgBouncer) URL for serverless/edge functions
# and the direct URL for migrations (drizzle-kit push/generate).
#
# Find both in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
